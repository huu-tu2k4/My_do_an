<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get-CRUD</title>
    <style>
        table {
        font-family: arial, sans-serif;
        border-collapse: collapse;
        width: 100%;
        }

        td, th {
        border: 1px solid #dddddd;
        text-align: left;
        padding: 8px;
        }

        tr:nth-child(even) {
        background-color: #dddddd;
        }
        .btn-edit {
            background-color: yellow;
            color: gray;
            margin-right: 20px;
        }
        .btn-delete {
            background-color: red;
            color: white;
        }
    </style>
</head>
<body>
    <table>
        <tr>
            <th>Email</th>
            <th>FirstName</th>
            <th>LastName</th>
            <th>Address</th>
            <th>Active</th>
        </tr>
        <% for(let i = 0; i < data.length; i++) { %>
            <tr>
                <td><%= data[i].email %></td>
                <td><%= data[i].firstName %></td>
                <td><%= data[i].lastName %></td>
                <td><%= data[i].address %></td>
                <td><a href="/edit-crud?id=<%= data[i].id %>" class="btn-edit" type="button">Edit</a>
                <a href="/delete-crud?id=<%= data[i].id %>" class="btn-delete" onclick="return confirm('Bạn có chắc muốn xóa?')">Delete</a></td>
            </tr>
        <% } %>
    </table>
</body>
</html>